# Copy to .env and fill in as needed. Everything here has a safe default for local dev.

DJANGO_SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated origins allowed to call this API (the Vite dev server).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Postgres URL for production, e.g. postgres://user:pass@host:5432/dbname
# Leave unset to use local SQLite.
DATABASE_URL=

# OpenAI — leave OPENAI_API_KEY unset to run with placeholder PDF summaries.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Cloudflare R2 — leave unset to store uploaded PDFs on local disk instead.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT_URL=
R2_SIGNED_URLS=True
